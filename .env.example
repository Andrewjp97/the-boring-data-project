# --- Site (Astro / Cloud Run) -------------------------------------------
# GA4 measurement ID (SPEC §7) — created in the GA4 console.
PUBLIC_GA_ID=
# Flip to 'true' only after AdSense approval (SPEC §8.5).
PUBLIC_ADS_ENABLED=false
# AdSense publisher client, e.g. ca-pub-1234567890123456
PUBLIC_ADSENSE_CLIENT=
# Amazon Associates tag, e.g. recalllookup-20
PUBLIC_AMAZON_TAG=
# Canonical origin, no trailing slash.
SITE_URL=https://recalllookup.example
SITE_NAME=RecallLookup

# --- Server-side Firestore access ----------------------------------------
# On Cloud Run these come from the runtime; locally set the project and
# either run the emulator or paste a token.
GCP_PROJECT=
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIRESTORE_ACCESS_TOKEN=$(gcloud auth print-access-token)
