---
/**
 * Client-side VIN decode -> redirect (SPEC §5). Calls NHTSA vPIC from the
 * browser (zero server cost), slugifies with the same rules as the ETL, and
 * redirects to the year page. noindex: utility page, no SEO value.
 */
import Layout from '../../layouts/Layout.astro';
import { buildPageDims } from '../../lib/ga';
import { SITE_NAME } from '../../lib/seo';

export const prerender = true;

const dims = buildPageDims({ kind: 'utility' });
---

<Layout
  title={`VIN Lookup — Find Your Vehicle's Recalls | ${SITE_NAME}`}
  description="Enter your 17-character VIN to jump to your vehicle's recall and complaint history."
  canonicalPath="/vin/"
  indexable={false}
  dims={dims}
>
  <h1>Find recalls by VIN</h1>
  <p>
    Enter your 17-character VIN (on the driver-side dashboard or door jamb). We decode the
    year, make, and model in your browser and take you to the matching recall page — the VIN
    itself never touches our servers.
  </p>

  <form id="vin-form">
    <input
      id="vin-input"
      name="vin"
      inputmode="text"
      autocomplete="off"
      spellcheck="false"
      minlength="11"
      maxlength="17"
      placeholder="e.g. 1HGRM4870GL123456"
      aria-label="Vehicle identification number"
      required
    />
    <button type="submit">Find my vehicle</button>
  </form>
  <p id="vin-status" role="status"></p>

  <p class="muted-note">
    To check whether <em>your specific car</em> has an open, unrepaired recall, use
    <a
      href="https://www.nhtsa.gov/recalls"
      rel="noopener"
      data-evt="outbound_nhtsa"
      data-evt-params='{"placement":"vin_page"}'
    >NHTSA's official VIN tool</a> — it queries manufacturer records directly.
  </p>
</Layout>

<script is:inline>
  (function () {
    var form = document.getElementById('vin-form');
    var input = document.getElementById('vin-input');
    var status = document.getElementById('vin-status');

    // Mirror of etl slugify()
    function slugify(v) {
      return v
        .trim()
        .toLowerCase()
        .replace(/&/g, ' and ')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function track(ok) {
      document.dispatchEvent(
        new CustomEvent('site-event', {
          detail: { name: 'vin_decode', params: { result: ok ? 'success' : 'fail' } },
        })
      );
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var vin = input.value.trim().toUpperCase();
      status.textContent = 'Decoding…';
      fetch(
        'https://vpic.nhtsa.dot.gov/api/vehicles/DecodeVinValues/' +
          encodeURIComponent(vin) +
          '?format=json'
      )
        .then(function (r) {
          return r.json();
        })
        .then(function (data) {
          var row = data.Results && data.Results[0];
          var make = row && row.Make;
          var model = row && row.Model;
          var year = row && row.ModelYear;
          if (make && model && year) {
            track(true);
            location.href = '/recalls/' + slugify(make) + '/' + slugify(model) + '/' + year + '/';
          } else {
            track(false);
            status.textContent =
              "Couldn't decode that VIN. Double-check it, or browse by make from the home page.";
          }
        })
        .catch(function () {
          track(false);
          status.textContent = 'The VIN decoder is unreachable right now. Please try again.';
        });
    });
  })();
</script>

<style>
  #vin-form {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
    margin: var(--sp-4) 0;
  }
  #vin-input {
    flex: 1 1 280px;
    padding: 11px 12px;
    font: var(--w-medium) var(--fs-body) / 1.4 var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--ink-900);
    background: var(--surface-card);
    border: 1px solid var(--border-strong);
    border-radius: var(--r-sm);
    box-shadow: var(--shadow-sm);
  }
  #vin-form button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: var(--w-semibold);
    line-height: 1;
    border: 1px solid var(--paper-ink);
    border-radius: var(--r-sm);
    background: var(--paper-ink);
    color: var(--ink-on-dark);
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease);
  }
  #vin-form button:hover {
    background: #22304a;
  }
  #vin-status {
    font-size: var(--fs-sm);
    color: var(--text-muted);
  }
</style>
