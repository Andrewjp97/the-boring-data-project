---
/**
 * Vanilla-JS typeahead island (SPEC §4): zero Firestore reads. Lazily
 * fetches /search-index.json on first keystroke, fuzzy-matches client-side.
 * Ships only on home/hub/404 pages. Magnifier glyph + dropdown with the
 * model-year range as mono metadata, per the design system.
 */
interface Props {
  placeholder?: string;
  initialQuery?: string;
  size?: 'md' | 'lg';
}

const {
  placeholder = 'Search a year, make, and model…',
  initialQuery = '',
  size = 'md',
} = Astro.props;
---

<div class={`searchbox ${size}`}>
  <svg
    class="glyph"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="8"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
  <input
    type="search"
    id="vehicle-search"
    placeholder={placeholder}
    value={initialQuery}
    autocomplete="off"
    aria-label="Search vehicles"
  />
  <ul id="vehicle-search-results" hidden></ul>
</div>

<script is:inline>
  (function () {
    var input = document.getElementById('vehicle-search');
    var list = document.getElementById('vehicle-search-results');
    var index = null;
    var loading = false;
    var failed = false;

    function loadIndex() {
      if (index || loading) return;
      loading = true;
      fetch('/search-index.json')
        .then(function (r) {
          if (!r.ok) throw new Error('http ' + r.status);
          return r.json();
        })
        .then(function (data) {
          index = data;
          failed = false;
          render(input.value);
        })
        .catch(function () {
          // Allow a retry on the next keystroke, but tell the user something
          // is wrong instead of failing silently.
          loading = false;
          failed = true;
          render(input.value);
        });
    }

    function score(entry, terms) {
      var hay = (entry.make + ' ' + entry.model).toLowerCase();
      var s = 0;
      for (var i = 0; i < terms.length; i++) {
        var t = terms[i];
        if (!t) continue;
        var pos = hay.indexOf(t);
        if (pos < 0) return -1;
        s += pos === 0 || hay[pos - 1] === ' ' || hay[pos - 1] === '-' ? 2 : 1;
      }
      return s;
    }

    function render(q) {
      q = q.trim().toLowerCase();
      if (q.length < 2) {
        list.hidden = true;
        list.innerHTML = '';
        return;
      }
      if (!index) {
        if (failed) {
          list.innerHTML =
            '<li class="search-error">Search is unavailable right now — ' +
            '<a href="/#makes">browse by make</a> instead.</li>';
          list.hidden = false;
        }
        return;
      }
      var terms = q.split(/\s+/);
      var matches = [];
      for (var i = 0; i < index.length; i++) {
        var s = score(index[i], terms);
        if (s >= 0) matches.push([s, index[i]]);
      }
      matches.sort(function (a, b) {
        return b[0] - a[0];
      });
      matches = matches.slice(0, 8);
      list.innerHTML = matches
        .map(function (m) {
          var e = m[1];
          var years = e.years && e.years.length ? e.years[0] + '–' + e.years[1] : '';
          return (
            '<li><a href="/' +
            e.slug +
            '/"><span class="label">' +
            e.make +
            ' ' +
            e.model +
            '</span>' +
            (years ? '<span class="meta">' + years + '</span>' : '') +
            '</a></li>'
          );
        })
        .join('');
      list.hidden = matches.length === 0;
      document.dispatchEvent(
        new CustomEvent('site-event', {
          detail: {
            name: 'search_used',
            params: { query_length: q.length, matched: matches.length > 0 },
          },
        })
      );
    }

    if (input) {
      input.addEventListener('focus', loadIndex);
      input.addEventListener('input', function () {
        loadIndex();
        render(input.value);
      });
      input.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter') return;
        var first = list.querySelector('li a[href]');
        if (first && !list.hidden) {
          e.preventDefault();
          location.href = first.getAttribute('href');
        }
      });
      if (input.value) {
        loadIndex();
      }
    }
  })();
</script>

<style>
  .searchbox {
    position: relative;
    max-width: 520px;
  }
  .glyph {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--ink-400);
  }
  .searchbox.lg .glyph {
    left: 16px;
  }
  #vehicle-search {
    width: 100%;
    padding: 11px 12px 11px 40px;
    font: var(--w-regular) var(--fs-body) / 1.4 var(--font-sans);
    color: var(--ink-900);
    background: var(--surface-card);
    border: 1px solid var(--border-strong);
    border-radius: var(--r-sm);
    outline: none;
    box-shadow: var(--shadow-sm);
  }
  .searchbox.lg #vehicle-search {
    padding: 16px 16px 16px 46px;
    font-size: var(--fs-lead);
  }
  #vehicle-search:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  #vehicle-search-results {
    position: absolute;
    z-index: 20;
    top: 100%;
    left: 0;
    right: 0;
    margin: 6px 0 0;
    padding: 4px;
    list-style: none;
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: var(--r-md);
    box-shadow: var(--shadow-lg);
    max-height: 320px;
    overflow-y: auto;
  }
  #vehicle-search-results :global(li a) {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 10px 12px;
    border-radius: var(--r-sm);
    text-decoration: none;
    font-size: var(--fs-body);
    color: var(--ink-900);
  }
  #vehicle-search-results :global(li a:hover) {
    background: var(--paper-sunken);
  }
  #vehicle-search-results :global(.label) {
    font-weight: var(--w-medium);
  }
  #vehicle-search-results :global(.meta) {
    margin-left: auto;
    font-size: var(--fs-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
  #vehicle-search-results :global(.search-error) {
    display: block;
    padding: 10px 12px;
    font-size: var(--fs-sm);
    color: var(--text-muted);
  }
</style>
