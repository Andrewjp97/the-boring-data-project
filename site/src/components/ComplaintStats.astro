---
/**
 * ComplaintStats — the top-components table with crash/fire/injury/death
 * counts and an inline bar chart (SPEC §5, section 5; no chart library —
 * widths are computed server-side). Each row: component name, a horizontal
 * bar sized to its complaint share, the complaint count, and severity chips.
 */
interface Stat {
  component: string;
  count: number;
  crashes: number;
  fires: number;
  injuries: number;
  deaths: number;
}

interface Props {
  stats: Stat[];
  total: number;
}

const { stats, total } = Astro.props;
const max = Math.max(1, ...stats.map((s) => s.count));
const sevMeta = [
  { key: 'crashes', label: 'crashes', cls: 'crash' },
  { key: 'fires', label: 'fires', cls: 'fire' },
  { key: 'injuries', label: 'injuries', cls: 'injury' },
  { key: 'deaths', label: 'deaths', cls: 'death' },
] as const;
---

{
  stats.length > 0 && (
    <div class="complaint-stats">
      {stats.map((s, i) => (
        <div class={`row${i % 2 ? ' zebra' : ''}`}>
          <div class="name">{s.component}</div>
          <div class="bar-cell">
            <div class="track" role="img" aria-label={`${s.count} complaints`}>
              <div class="bar" style={`width:${Math.round((s.count / max) * 100)}%`} />
            </div>
            <span class="count">{s.count.toLocaleString('en-US')}</span>
          </div>
          <div class="sev">
            {sevMeta.map((m) =>
              s[m.key] ? (
                <span class={`chip ${m.cls}`} title={m.label}>
                  <span class="dot" aria-hidden="true" />
                  {s[m.key]}
                  <span class="sr-only"> {m.label}</span>
                </span>
              ) : null,
            )}
          </div>
        </div>
      ))}
      <div class="total">
        <span class="total-label">Total complaints</span>
        <span class="total-count">{total.toLocaleString('en-US')}</span>
      </div>
    </div>
  )
}

<style>
  .complaint-stats {
    border: 1px solid var(--border-default);
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--surface-card);
  }
  .row {
    display: grid;
    grid-template-columns: minmax(140px, 1.4fr) minmax(120px, 2fr) auto;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-3) var(--sp-4);
    border-top: 1px solid var(--border-default);
  }
  .row:first-child {
    border-top: none;
  }
  .row.zebra {
    background: var(--paper-sunken);
  }
  .name {
    font: var(--type-sm);
    font-weight: var(--w-medium);
    color: var(--ink-900);
  }
  .bar-cell {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .track {
    flex: 1;
    height: 10px;
    background: var(--paper-sunken);
    border-radius: 2px;
    overflow: hidden;
    min-width: 40px;
  }
  .bar {
    height: 100%;
    background: var(--ink-700);
    border-radius: 2px;
  }
  .count {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-900);
    font-variant-numeric: tabular-nums;
    min-width: 34px;
    text-align: right;
  }
  .sev {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-variant-numeric: tabular-nums;
  }
  .chip .dot {
    width: 7px;
    height: 7px;
    border-radius: var(--r-full);
    display: inline-block;
    background: currentColor;
  }
  .chip.crash {
    color: var(--sev-crash);
  }
  .chip.fire {
    color: var(--sev-fire);
  }
  .chip.injury {
    color: var(--sev-injury);
  }
  .chip.death {
    color: var(--sev-death);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .total {
    padding: var(--sp-3) var(--sp-4);
    border-top: 1px solid var(--border-strong);
    background: var(--paper-sunken);
    display: flex;
    justify-content: space-between;
    font-size: var(--fs-xs);
    color: var(--text-muted);
  }
  .total-label {
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-weight: var(--w-semibold);
  }
  .total-count {
    font-family: var(--font-mono);
    color: var(--ink-900);
    font-weight: var(--w-semibold);
  }
  @media (max-width: 560px) {
    .row {
      grid-template-columns: 1fr;
      gap: var(--sp-2);
    }
    .sev {
      justify-content: flex-start;
    }
  }
</style>
