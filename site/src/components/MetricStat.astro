---
/**
 * MetricStat — a single big-number summary figure (recall count, total
 * complaints, estimated vehicles affected). Mono numerals, tabular. Used in
 * the summary strip below the H1 on entity pages. `tone` accents the value.
 */
interface Props {
  value: string | number;
  label: string;
  sublabel?: string;
  tone?: 'default' | 'recall' | 'danger' | 'safe';
}

const { value, label, sublabel, tone = 'default' } = Astro.props;
---

<div class="metric-stat">
  <div class={`value ${tone}`}>{value}</div>
  <div class="label">{label}</div>
  {sublabel && <div class="sublabel">{sublabel}</div>}
</div>

<style>
  .metric-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    align-items: flex-start;
  }
  .value {
    font-family: var(--font-mono);
    font-weight: var(--w-semibold);
    font-size: 30px;
    line-height: 1;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
    color: var(--ink-900);
  }
  .value.recall {
    color: var(--amber-600);
  }
  .value.danger {
    color: var(--red-600);
  }
  .value.safe {
    color: var(--green-600);
  }
  .label {
    font-family: var(--font-sans);
    font-size: var(--fs-xs);
    font-weight: var(--w-medium);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    color: var(--text-muted);
  }
  .sublabel {
    font-size: var(--fs-xs);
    color: var(--text-faint);
  }
</style>
