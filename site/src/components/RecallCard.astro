---
/**
 * One recall campaign on a list page (SPEC §5, section 3). Header row with
 * component badge + campaign number + report date + units affected; then
 * defect / consequence / remedy blocks; footer links to the campaign detail
 * page. Sturdy hairline card, no colored left-border trope.
 */
interface Recall {
  campno: string;
  component: string | null;
  reportDate: string | null;
  affected: number | null;
  defect: string | null;
  consequence: string | null;
  action: string | null;
  mfgCampno: string | null;
  doNotDrive?: boolean;
  parkOutside?: boolean;
}

interface Props {
  recall: Recall;
}

const { recall } = Astro.props;
const componentBadge = recall.component ? recall.component.split(':')[0] : 'UNKNOWN';
const fmt = (n: number) => n.toLocaleString('en-US');
---

<article class="recall-card">
  <header>
    <span class="badge recall">{componentBadge}</span>
    <span class="badge neutral mono">{recall.campno}</span>
    {recall.doNotDrive && <span class="badge danger">Do Not Drive</span>}
    {recall.parkOutside && <span class="badge danger">Park Outside</span>}
    <span class="meta">
      {recall.reportDate && <span class="date">{recall.reportDate}</span>}
      {
        recall.affected != null && recall.affected > 0 && (
          <span class="affected">
            <strong>{fmt(recall.affected)}</strong> affected
          </span>
        )
      }
    </span>
  </header>
  <div class="fields">
    {
      recall.defect && (
        <div class="field">
          <div class="rr-eyebrow">Defect</div>
          <p>{recall.defect}</p>
        </div>
      )
    }
    {
      recall.consequence && (
        <div class="field">
          <div class="rr-eyebrow">Consequence</div>
          <p>{recall.consequence}</p>
        </div>
      )
    }
    {
      recall.action && (
        <div class="field">
          <div class="rr-eyebrow">Remedy</div>
          <p>{recall.action}</p>
        </div>
      )
    }
  </div>
  <footer>
    <a href={`/recall/${recall.campno}/`}>Full campaign details <span class="arrow" aria-hidden="true">→</span></a>
  </footer>
</article>

<style>
  .recall-card {
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: var(--r-md);
    padding: var(--sp-5);
    box-shadow: var(--shadow-sm);
  }
  .recall-card header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--border-default);
    margin-bottom: var(--sp-4);
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-sans);
    font-weight: var(--w-semibold);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 3px 8px;
    border-radius: var(--r-xs);
    white-space: nowrap;
    line-height: 1.2;
  }
  .badge.recall {
    color: var(--amber-600);
    background: var(--amber-50);
    border: 1px solid var(--amber-100);
  }
  .badge.neutral {
    color: var(--ink-700);
    background: var(--paper-sunken);
    border: 1px solid var(--line-strong);
  }
  .badge.mono {
    font-family: var(--font-mono);
    text-transform: none;
    letter-spacing: 0;
  }
  .badge.danger {
    color: var(--red-600);
    background: var(--red-50);
    border: 1px solid var(--red-100);
  }
  .meta {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .meta .date {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--text-muted);
  }
  .meta .affected {
    font-size: var(--fs-xs);
    color: var(--text-body);
  }
  .meta .affected strong {
    font-family: var(--font-mono);
    color: var(--ink-900);
  }
  .fields {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .field .rr-eyebrow {
    margin-bottom: 3px;
  }
  .field p {
    font: var(--type-prose);
    color: var(--ink-700);
    font-size: var(--fs-sm);
    margin: 0;
  }
  .recall-card footer {
    margin-top: var(--sp-4);
    padding-top: var(--sp-3);
    border-top: 1px solid var(--border-default);
  }
  .recall-card footer a {
    font-size: var(--fs-sm);
    font-weight: var(--w-medium);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .arrow {
    font-family: var(--font-mono);
  }
</style>
