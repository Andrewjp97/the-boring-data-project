---
/**
 * Component-keyword-mapped Amazon picks (SPEC §8.6). Renders only when
 * PUBLIC_AMAZON_TAG is set. rel="sponsored", labeled, FTC disclosure.
 * Card with a "Sponsored" eyebrow and a grid of product links.
 */
import affiliateMap from '../data/affiliate-map.json';

interface Props {
  topComponent?: string | null;
  make?: string | null;
  model?: string | null;
  year?: number | null;
}

const { topComponent, make, model, year } = Astro.props;
const tag = import.meta.env.PUBLIC_AMAZON_TAG; // e.g. recallrepo-20

interface Product {
  asin: string;
  title: string;
  searchTemplate?: string;
}
interface Group {
  keywords: string[];
  asinGroup: string;
  heading: string;
  products: Product[];
}

const comp = (topComponent ?? '').toUpperCase();
const groups = (affiliateMap.groups as Group[]).filter(
  (g) =>
    g.products.some((p) => !p.asin.startsWith('PLACEHOLDER') || p.searchTemplate) &&
    (g.keywords.length === 0 || g.keywords.some((k) => comp.includes(k))),
);

function productUrl(p: Product): string {
  if (p.searchTemplate && make && model) {
    const q = p.searchTemplate
      .replace('{make}', make)
      .replace('{model}', model)
      .replace('{year}', year ? String(year) : '');
    return `https://www.amazon.com/s?k=${encodeURIComponent(q.trim())}&tag=${tag}`;
  }
  return `https://www.amazon.com/dp/${p.asin}?tag=${tag}`;
}
---

{
  tag && groups.length > 0 && (
    <aside class="affiliate-block">
      <div class="head">
        <h3>Owner tools</h3>
        <span class="rr-eyebrow sponsored">Sponsored</span>
      </div>
      {groups.map((g) => (
        <div class="group">
          <div class="rr-eyebrow group-heading">{g.heading}</div>
          <div class="products">
            {g.products
              .filter((p) => !p.asin.startsWith('PLACEHOLDER') || p.searchTemplate)
              .map((p) => (
                <a
                  href={productUrl(p)}
                  rel="sponsored nofollow noopener"
                  target="_blank"
                  data-evt="affiliate_click"
                  data-evt-params={JSON.stringify({
                    component: comp || 'none',
                    asin_group: g.asinGroup,
                  })}
                >
                  <span class="title">{p.title}</span>
                  <span class="cta">View on Amazon →</span>
                </a>
              ))}
          </div>
        </div>
      ))}
      <p class="disclosure">
        As an Amazon Associate we earn from qualifying purchases. This does not affect the recall
        data above.
      </p>
    </aside>
  )
}

<style>
  .affiliate-block {
    border: 1px solid var(--border-default);
    border-radius: var(--r-md);
    background: var(--surface-card);
    padding: var(--sp-5);
    margin: var(--block) 0;
  }
  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .head h3 {
    margin: 0;
  }
  .sponsored {
    color: var(--text-faint);
  }
  .group + .group {
    margin-top: var(--sp-4);
  }
  .group-heading {
    margin-bottom: var(--sp-2);
  }
  .products {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--sp-3);
  }
  .products a {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--sp-3);
    border: 1px solid var(--border-default);
    border-radius: var(--r-sm);
    background: var(--paper);
    color: var(--ink-900);
    text-decoration: none;
    transition: border-color var(--dur-fast) var(--ease);
  }
  .products a:hover {
    border-color: var(--border-strong);
    text-decoration: none;
  }
  .products .title {
    font-size: var(--fs-sm);
    font-weight: var(--w-medium);
    line-height: 1.35;
  }
  .products .cta {
    font-size: var(--fs-xs);
    color: var(--text-link);
    font-weight: var(--w-medium);
  }
  .disclosure {
    margin: var(--sp-4) 0 0;
    font-size: var(--fs-xs);
    color: var(--text-muted);
    font-family: var(--font-serif);
    font-style: italic;
    line-height: 1.5;
  }
</style>
