---
/**
 * Breadcrumbs — the entity hierarchy trail (Home / Honda / CR-V / 2016).
 * Mirrors the BreadcrumbList JSON-LD. Last item is the current page (not a
 * link). Mono "/" separator per the design system.
 */
import type { Crumb } from '../lib/seo';

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {
      crumbs.map((c, i) => (
        <li>
          {i < crumbs.length - 1 ? (
            <a href={c.path}>{c.name}</a>
          ) : (
            <span class="current" aria-current="page">{c.name}</span>
          )}
          {i < crumbs.length - 1 && <span class="sep" aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    list-style: none;
    padding: 0;
    margin: 0 0 var(--sp-5);
    font-size: var(--fs-xs);
    font-family: var(--font-sans);
  }
  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .breadcrumbs a {
    color: var(--text-muted);
  }
  .breadcrumbs .current {
    color: var(--ink-700);
    font-weight: var(--w-medium);
  }
  .breadcrumbs .sep {
    color: var(--ink-400);
    font-family: var(--font-mono);
  }
</style>
