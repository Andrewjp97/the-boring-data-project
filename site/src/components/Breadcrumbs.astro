---
import type { Crumb } from '../lib/seo';

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {
      crumbs.map((c, i) => (
        <li>
          {i < crumbs.length - 1 ? <a href={c.path}>{c.name}</a> : <span aria-current="page">{c.name}</span>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .breadcrumbs li + li::before {
    content: '›';
    margin: 0 0.35rem;
    color: var(--muted);
  }
</style>
